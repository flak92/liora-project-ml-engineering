# Copy this file to `.env` and fill in the key you need. `.env` is git-ignored, here and
# anywhere else in the tree. NEVER commit a real key. If one ever reaches a remote, rotate
# it at the provider — deleting the commit is not enough, because it stays in the history
# of every clone that already fetched it.
#
# Nothing else in this console needs a key. Every page, and `make verify`, work without
# this file existing at all.

# Used by the optional Formular questionnaire on the Basket Simulator (app/formular/).
# One API call per submitted questionnaire.
ANTHROPIC_API_KEY=

# PREPARED BUT UNUSED. No code in this repository reads this variable — it is here only so
# the shape is visible if the adviser is ever ported to another provider. Leaving it empty
# changes nothing.
OPENAI_API_KEY=
