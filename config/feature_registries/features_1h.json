{
  "schema_version": "feature_registry.simple.v1",
  "namespace": "1h",
  "id_range": "01-99",
  "_meta": {
    "purpose": "Simple 1h OHLCV feature registry. Every feature is computed at the 1h decision bar with candles available up to that bar close.",
    "causal_clock": "1h decision timestamp = close of the signal bar"
  },
  "features": [
    {"id": 1, "name": "direction", "implemented": true, "formula": "sign(log_return_5)", "unit": "{-1,+1}"},
    {"id": 2, "name": "log_return_1", "implemented": true, "formula": "ln(close[t] / close[t-1])", "unit": "ln"},
    {"id": 3, "name": "log_return_5", "implemented": true, "formula": "ln(close[t] / close[t-5])", "unit": "ln"},
    {"id": 4, "name": "log_return_20", "implemented": true, "formula": "ln(close[t] / close[t-20])", "unit": "ln"},
    {"id": 5, "name": "close_z_score_20", "implemented": true, "formula": "(close[t] - SMA20[t]) / std20[t]", "unit": "z"},
    {"id": 6, "name": "dist_to_sma_20", "implemented": true, "formula": "close[t] / SMA20[t] - 1", "unit": "ratio"},
    {"id": 7, "name": "dist_to_sma_50", "implemented": true, "formula": "close[t] / SMA50[t] - 1", "unit": "ratio"},
    {"id": 8, "name": "sma_20_sma_50_ratio", "implemented": true, "formula": "SMA20[t] / SMA50[t] - 1", "unit": "ratio"},
    {"id": 9, "name": "volume_z_score_20", "implemented": true, "formula": "(volume[t] - mean20(volume)[t]) / std20(volume)[t]", "unit": "z"},
    {"id": 10, "name": "atr_pct_14", "implemented": true, "formula": "100 * WilderATR14[t] / close[t]", "unit": "%"},
    {"id": 11, "name": "realized_volatility_20", "implemented": true, "formula": "std20(log_return_1) * sqrt(20)", "unit": "ln"},
    {"id": 12, "name": "rsi_14", "implemented": true, "formula": "Wilder RSI14[t]", "unit": "0-100"},
    {"id": 13, "name": "bollinger_percent_b_20_2", "implemented": true, "formula": "(close[t] - lower_band20_2[t]) / (upper_band20_2[t] - lower_band20_2[t])", "unit": "ratio"},
    {"id": 14, "name": "bollinger_bandwidth_20_2", "implemented": true, "formula": "(upper_band20_2[t] - lower_band20_2[t]) / SMA20[t]", "unit": "ratio"},
    {"id": 15, "name": "macd_line_12_26_9", "implemented": true, "formula": "EMA12(close)[t] - EMA26(close)[t]", "unit": "price"},
    {"id": 16, "name": "macd_signal_12_26_9", "implemented": true, "formula": "EMA9(MACD line)[t]", "unit": "price"},
    {"id": 17, "name": "macd_hist_12_26_9", "implemented": true, "formula": "MACD line[t] - MACD signal[t]", "unit": "price"}
  ]
}
