{
  "schema_version": "sample.v2",
  "rule": "Tables only \u2014 no sector, no issuer, no company. Filter the 498 Train-window tables on graded data quality (thresholds are this store's own quantiles), rank the survivors cleanest-first by price resolution then by frozen-bar share, and walk down that ranking taking the first 20 that are not numerically redundant (bar-return correlation > 0.95) with something already taken. No OOS bar is read and no result is consulted.",
  "train_window": {
    "start": "2016-10-17",
    "end": "2023-12-29"
  },
  "oos_window_not_read": "2024-01-02 -> 2026-05-29",
  "source_store": "xgb/data/liora.duckdb",
  "source_profile": "config/table_profile.json",
  "filters": [
    {
      "filter": "coverage >= 0.99",
      "rejects": "bars present across the Train window",
      "threshold_from": "population q05 is 0.772 and q25 is 0.998 \u2014 the tail below 0.99 is short history, not a hole",
      "dropped": 37,
      "remaining": 461
    },
    {
      "filter": "gaps == 0",
      "rejects": "no stretch longer than four days without a bar",
      "threshold_from": "q00..q95 are all 0; only a handful of tables carry any",
      "dropped": 1,
      "remaining": 460
    },
    {
      "filter": "max_gap_hours <= 100",
      "rejects": "the largest hole is a long weekend, not a hiatus",
      "threshold_from": "q00..q95 sit at 90..93 h (a normal long weekend); q100 reaches 13,890 h",
      "dropped": 0,
      "remaining": 460
    },
    {
      "filter": "violent_bars == 0",
      "rejects": "no single bar moves more than 35% in log terms",
      "threshold_from": "q00..q75 are 0; such a bar smells of an event the split adjustment did not close",
      "dropped": 22,
      "remaining": 438
    },
    {
      "filter": "max_abs_log_return <= 0.35",
      "rejects": "the same condition stated on the maximum",
      "threshold_from": "q100 reaches 1.78, i.e. +495% inside one hour",
      "dropped": 0,
      "remaining": 438
    },
    {
      "filter": "flat_share <= 0.0052",
      "rejects": "few bars repeat the previous close",
      "threshold_from": "population q25 \u2014 frozen bars break rolling statistics and z-scores",
      "dropped": 330,
      "remaining": 108
    },
    {
      "filter": "price_resolution >= 0.7489",
      "rejects": "prices resolve into many distinct values",
      "threshold_from": "population q75 \u2014 a low-resolution table is a lattice, and its features quantise with it",
      "dropped": 21,
      "remaining": 87
    }
  ],
  "redundancy": {
    "max_correlation": 0.95,
    "rejected": [
      {
        "ticker": "GOOGL",
        "duplicate_of": "GOOG",
        "correlation": 0.9916
      }
    ]
  },
